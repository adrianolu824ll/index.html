<style>

*{
margin:0;
padding:0;
box-sizing:border-box;
font-family:Poppins,sans-serif;
}

body{
background:linear-gradient(to bottom,#ffffff,#fff0f6,#ffe4ef);
overflow-x:hidden;
color:#d63384;
}

/* Flores */
.flor{
position:fixed;
font-size:35px;
opacity:.25;
animation:flutuar 8s infinite ease-in-out;
}

.f1{top:20px;left:20px;}
.f2{top:90px;right:30px;}
.f3{bottom:50px;left:30px;}
.f4{bottom:70px;right:30px;}
.f5{top:45%;left:5%;}
.f6{top:55%;right:5%;}

@keyframes flutuar{
50%{
transform:translateY(-15px) rotate(15deg);
}
}

/* Cabeçalho */

header{
background:linear-gradient(135deg,#ffd6e8,#ffffff);
padding:70px 20px;
text-align:center;
box-shadow:0 5px 20px rgba(255,105,180,.2);
}

header h1{
font-family:Great Vibes,cursive;
font-size:75px;
color:#ff1493;
}

header p{
font-size:20px;
margin-top:10px;
}

.emoji{
font-size:35px;
margin-top:20px;
}

/* Conteúdo */

.container{
max-width:1100px;
margin:auto;
padding:40px 20px;
}

.card{
background:white;
padding:35px;
margin-bottom:30px;
border-radius:25px;
box-shadow:0 10px 30px rgba(255,105,180,.15);
border:2px solid #ffd6e8;
text-align:center;
}

.card h2{
margin-bottom:15px;
color:#ff1493;
}

.icones{
display:grid;
grid-template-columns:repeat(auto-fit,minmax(120px,1fr));
gap:20px;
margin-top:20px;
}

.item{
background:#fff3f8;
padding:20px;
border-radius:20px;
font-size:45px;
transition:.3s;
}

.item:hover{
transform:scale(1.1);
}

.botoes{
display:flex;
justify-content:center;
gap:20px;
flex-wrap:wrap;
margin-top:25px;
}

.botao{
background:#ff4fa3;
padding:16px 35px;
border-radius:50px;
text-decoration:none;
color:white;
font-weight:bold;
font-size:18px;
transition:.3s;
}

.botao:hover{
background:#d81b60;
transform:translateY(-3px);
}

footer{
background:#ffd6e8;
padding:30px;
text-align:center;
color:#c2185b;
font-weight:bold;
margin-top:40px;
}

</style>

